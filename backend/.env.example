NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://smarttodo:smarttodo@localhost:5432/smarttodo?schema=public"
REDIS_URL="redis://localhost:6379"

SESSION_COOKIE_NAME="smarttodo.sid"
SESSION_SECRET="replace-with-at-least-32-characters-session-secret"
AI_KEY_ENCRYPTION_SECRET="replace-with-at-least-32-characters-ai-key-secret"

UPLOAD_DIR="uploads"
SOFT_DELETE_RETENTION_DAYS=3

WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:admin@example.com"
