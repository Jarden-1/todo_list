{
  "name": "smarttodo-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SmartTodo backend API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "NODE_ENV=test DATABASE_URL=postgresql://test:test@localhost:5432/test SESSION_SECRET=test-session-secret-at-least-32-characters AI_KEY_ENCRYPTION_SECRET=test-ai-key-secret-at-least-32-characters node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@prisma/client": "^6.10.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
